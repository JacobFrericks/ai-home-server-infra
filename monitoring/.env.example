# Copy this file to monitoring/.env on the server and fill in real values.
# NEVER commit the real monitoring/.env.
#
# Docker Compose resolves ${VAR} interpolation (and its default .env file)
# relative to the directory of the compose file passed via -f — NOT the
# working directory the command is run from. Since we run
# `docker compose -f monitoring/docker-compose.yml ...` from the repo root,
# Compose looks for monitoring/.env here, not the repo-root .env.
# (Verified empirically; see monitoring/README.md.)

# Grafana admin login. Generate with:  openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_OPENSSL_RAND_BASE64_24

# Plex auth token, used by plex-exporter to read session/library stats.
# Read it from the running container:
#   docker exec plex cat "/config/Library/Application Support/Plex Media Server/Preferences.xml" | grep -o 'PlexOnlineToken="[^"]*"'
PLEX_TOKEN=REPLACE_WITH_PLEX_TOKEN

# Home Assistant's Prometheus scrape token is NOT here — it's the separate
# git-ignored file monitoring/prometheus/ha_token (chmod 600). See
# monitoring/README.md.
