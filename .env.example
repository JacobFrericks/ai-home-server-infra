# Copy this file to .env and fill in a real value. NEVER commit the real .env.
# Generate a strong key with:  openssl rand -hex 32
WEBUI_SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32

# NOTE: the monitoring stack (monitoring/docker-compose.yml) does NOT read
# this file. Docker Compose resolves ${VAR} interpolation and the default
# .env against the directory of the compose file passed via -f, not the
# working directory — so its secrets live in monitoring/.env instead. See
# monitoring/.env.example.
