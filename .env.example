# Copy this file to .env and fill in a real value. NEVER commit the real .env.
# Generate a strong key with:  openssl rand -hex 32
WEBUI_SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32

# comfyui-mcp image delivery via Open WebUI's files API (see docker-compose.yml).
# OWUI_PUBLIC_URL: the origin clients use to reach Open WebUI. It MUST match the
#   server URL configured in the mobile client (Conduit) exactly, or the mobile
#   client won't attach its auth token to same-origin image requests.
# OWUI_USER_ID: the Open WebUI user whose files the MCP uploads as. Find it with:
#   docker exec open-webui python3 -c \
#     "import sqlite3;print(sqlite3.connect('/app/backend/data/webui.db').execute('select id from user order by created_at limit 1').fetchone()[0])"
OWUI_PUBLIC_URL=http://192.168.86.63:8080
OWUI_USER_ID=REPLACE_WITH_OPEN_WEBUI_USER_ID

# NOTE: the monitoring stack (monitoring/docker-compose.yml) does NOT read
# this file. Docker Compose resolves ${VAR} interpolation and the default
# .env against the directory of the compose file passed via -f, not the
# working directory — so its secrets live in monitoring/.env instead. See
# monitoring/.env.example.
